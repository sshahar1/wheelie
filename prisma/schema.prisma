generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerformanceStatus {
  upcoming
  cancelled
}

model TroupeMember {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String   @unique
  createdAt   DateTime @default(now())

  createdPerformances      Performance[] @relation("CreatedBy")
  lastUpdatedPerformances  Performance[] @relation("LastUpdatedBy")

  @@map("troupe_members")
}

model Performance {
  id        String            @id @default(uuid())
  date      DateTime          @db.Date
  time      DateTime?         @db.Time
  location  String
  notes     String?
  status    PerformanceStatus @default(upcoming)

  createdByMemberId      String
  createdBy              TroupeMember @relation("CreatedBy", fields: [createdByMemberId], references: [id])
  lastUpdatedByMemberId  String
  lastUpdatedBy          TroupeMember @relation("LastUpdatedBy", fields: [lastUpdatedByMemberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
  @@map("performances")
}
